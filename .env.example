# ──────────────────────────────────────────────
# autoRiff — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The CLI also supports --provider and --base-url
# flags to override these at runtime.

# ── LLM Provider ─────────────────────────────
# Which backend to use: "anthropic" (default) or "openai"
# The "openai" provider works with any OpenAI-compatible API:
# LM Studio, Ollama, vLLM, Together, OpenRouter, etc.
LLM_PROVIDER=anthropic

# ── Anthropic ────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI-compatible ────────────────────────
# Required when LLM_PROVIDER=openai
# Common base URLs:
#   LM Studio:  http://localhost:1234/v1
#   Ollama:     http://localhost:11434/v1
#   vLLM:       http://localhost:8000/v1
#   OpenRouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=lm-studio

# ── Models ───────────────────────────────────
# DEFAULT_MODEL — used for planning and turn generation (the "smart" work)
# FAST_MODEL    — used for insight extraction, summarization, feedback
#                 validation (mechanical tasks that don't need reasoning)
#
# With Claude, FAST_MODEL (Haiku) is ~60x cheaper than DEFAULT_MODEL (Sonnet).
# For local models, set both to the same model.
DEFAULT_MODEL=claude-sonnet-4-5-20250929
FAST_MODEL=claude-haiku-4-5-20251001

# Max tokens for the main turn agent output
MAX_OUTPUT_TOKENS=16384

# Override token budget for fast/utility LLM calls.
# Default: 256-1024 depending on the task.
# Thinking models (Qwen3, DeepSeek-R1, etc.) generate <think>...</think>
# reasoning tokens that consume the budget before producing output.
# Set to 4096+ for thinking models.
# FAST_MAX_TOKENS=4096

# ── Temporal ─────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Temporal Cloud (uncomment for production):
# TEMPORAL_ADDRESS=your-namespace.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=your-namespace
# TEMPORAL_API_KEY=your-api-key

# ── Workspace ────────────────────────────────
# Base directory for session artifacts (turn files, summaries)
# AUTORIFF_WORKSPACE=.autoriff
